{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@ui": [
        "./packages/ui/index.ts"
      ],
      "@ui/*": [
        "./packages/ui/*"
      ],
      "@config-engine": [
        "./packages/config-engine/index.ts"
      ],
      "@config-engine/*": [
        "./packages/config-engine/*"
      ],
      "@form-engine": [
        "./packages/form-engine/index.ts"
      ],
      "@form-engine/*": [
        "./packages/form-engine/*"
      ],
      "@auth": [
        "./packages/auth/index.ts"
      ],
      "@auth/*": [
        "./packages/auth/*"
      ],
      "@native": [
        "./packages/native/index.ts"
      ],
      "@native/*": [
        "./packages/native/*"
      ],
      "@modules/*": [
        "./modules/*"
      ],
      "@db/*": [
        "./db/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    ".next-dash/types/**/*.ts",
    ".next-dash/dev/types/**/*.ts",
    ".next-verify/types/**/*.ts",
    ".next-verify/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
