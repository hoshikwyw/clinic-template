# ---------------------------------------------------------------------------
# Clinic Platform — environment variables
# Copy to .env.local and fill in. NEVER commit real secrets.
# ---------------------------------------------------------------------------

# Supabase (Auth, Storage, public API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Database (Drizzle). Use the Supabase connection POOLER URL (port 6543).
# Example: postgresql://postgres.<ref>:<password>@aws-...pooler.supabase.com:6543/postgres
DATABASE_URL=

# Email (Resend) — appointment reminders / transactional mail.
# Optional: with no key, emails are logged to the console (no-op), not sent.
RESEND_API_KEY=
# From address for outgoing email (must be a Resend-verified domain in prod).
EMAIL_FROM="Clinic <onboarding@resend.dev>"

# Secret protecting the reminders cron endpoint (/api/cron/reminders).
# Vercel Cron sends this automatically as a Bearer token when set.
CRON_SECRET=
