# ---------------------------------------------------------------------------
# Clinic Platform — environment variables
# Copy to .env.local and fill in. NEVER commit real secrets.
# ---------------------------------------------------------------------------

# Supabase (Auth, Storage, public API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Database (Drizzle). Use the Supabase connection POOLER URL (port 6543).
# Example: postgresql://postgres.<ref>:<password>@aws-...pooler.supabase.com:6543/postgres
DATABASE_URL=

# Email (Resend) — appointment reminders / transactional mail
RESEND_API_KEY=
